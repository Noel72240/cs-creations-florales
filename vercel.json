{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/validate-promo-code",
      "destination": "/api/create-sumup-checkout"
    },
    {
      "source": "/api/confirm-checkout-return",
      "destination": "/api/create-sumup-checkout"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
