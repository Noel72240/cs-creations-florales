# Copier vers .env en local. Sur Vercel : Project → Settings → Environment Variables (Production + Preview).

# --- Vite / site ---
# URL publique du site (canonical, sitemap, Open Graph) — obligatoire en production
# VITE_SITE_URL=https://www.votre-domaine.fr

# Image de fond de la page d’accueil (optionnel)
# VITE_HERO_BG=https://exemple.com/mon-fond.jpg

# Lien de paiement SumUp manuel (page /paiement si pas de panier) — optionnel
# VITE_SUMUP_PAYMENT_URL=https://pay.sumup.io/b/xxxxxxxx

# URL de base de l’API checkout (uniquement si le front et l’API ne sont pas sur le même origine)
# Ex. http://localhost:3000 quand vous lancez `vercel dev` sur le port 3000 et `vite` sur 5173 avec proxy ci‑dessous
# VITE_SUMUP_CHECKOUT_API_URL=http://localhost:3000

# Proxy Vite → API en local (optionnel) : même valeur que l’origine où tourne `vercel dev`
# VITE_DEV_API_PROXY=http://localhost:3000

# Administration (page /admin)
# VITE_ADMIN_PASSWORD=votre_mot_de_passe_securise

# --- Persistance du contenu éditable (ÉTAPE 1 Supabase) ---
# local = localStorage [défaut en dev]
# supabase = contenu lu/écrit dans la table site_content (voir supabase/README.md)
# VITE_FORCE_ZERO_PRICES=false   # après livraison : afficher les prix saisis dans l’admin

# Projet Supabase : Settings → API
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Puis exécuter supabase/setup-complet.sql (section 1) dans le SQL Editor
#
# En local (npm run dev) — enregistrement admin vers Supabase :
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Settings → API → service_role (secret)
# ADMIN_PASSWORD=                    # même valeur que VITE_ADMIN_PASSWORD
# SUPABASE_URL=https://xxxx.supabase.co

# Bucket Storage public (même nom que dans Supabase → Storage). Admin : connexion Auth Supabase + upload depuis /admin
# VITE_SUPABASE_STORAGE_BUCKET=site-images

# =============================================================================
# Variables UNIQUEMENT pour le serveur (Vercel → Settings → Environment Variables)
# ou fichier .env.local chargé par `vercel dev` (pas besoin du préfixe VITE_).
# =============================================================================
#
# SUMUP_API_KEY=              # Clé API SumUp (Bearer) — dashboard SumUp → API keys
# SUMUP_MERCHANT_CODE=        # Optionnel : sinon récupéré via GET https://api.sumup.com/v0.1/me
# SUMUP_PAY_TO_EMAIL=         # Optionnel : stocké sur la ligne commande (traçabilité)
#
# Code promo 1ère commande (validé côté API — doit correspondre à la bannière du site)
# PROMO_WELCOME_CODE=Bienvenuecscreationflorale10
# PROMO_WELCOME_PERCENT=10
# PROMO_WELCOME_MIN_EUR=35
# PROMO_WELCOME_FIRST_ORDER_ONLY=false   # true par défaut côté navigateur ; l’API n’impose pas la 1ère commande
#
# Maintenance (urgence — bloque les paiements SumUp même sans admin Supabase)
# SITE_MAINTENANCE=true
# SITE_MAINTENANCE_MESSAGE=Site en maintenance. Paiements suspendus.
#
# APP_URL=http://localhost:5173   # Origine du site (redirect SumUp après paiement). Sur Vercel : https://votre-domaine.fr
#                                   # Plusieurs origines : séparées par des virgules (CORS).
#
# SUPABASE_URL=               # Même valeur que VITE_SUPABASE_URL (recommandé côté serveur)
# SUPABASE_SERVICE_ROLE_KEY=  # OBLIGATOIRE : commandes SumUp + enregistrement admin (site_content, photos)
# ADMIN_PASSWORD=             # Même mot de passe que VITE_ADMIN_PASSWORD (vérifie les API /api/save-site-content, upload)
# SUPABASE_STORAGE_BUCKET=    # Même que VITE_SUPABASE_STORAGE_BUCKET (upload photos admin)
